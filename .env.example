# ============================================================
# .env — API Keys
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git (it's in .gitignore).
# ============================================================

# Required: Google Gemini API key
# Get yours free at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Anthropic Claude API key (for enrichment pass)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Wolfram Alpha App ID (for math validation)
# Get yours free at: https://products.wolframalpha.com/api/
WOLFRAM_APP_ID=your_wolfram_app_id_here
